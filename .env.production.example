# ============================================
# PR|ERP — Production Environment Variables
# ============================================
# Copy this file to .env.production and fill in real values
# DO NOT commit .env.production to git!

# Django
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=CHANGE-ME-generate-with-python-c-import-secrets-secrets.token_urlsafe-50
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=srv1248490.hstgr.cloud

# CSRF / CORS
CSRF_TRUSTED_ORIGINS=https://srv1248490.hstgr.cloud
CORS_ALLOWED_ORIGINS=https://srv1248490.hstgr.cloud
DJANGO_SECURE_SSL=true

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=erp_prod
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=CHANGE-ME-use-a-strong-password

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Sentry (optional)
SENTRY_DSN=

# SSO (optional)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
